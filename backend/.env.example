# System Configuration
ENV=development
DEBUG=true
SECRET_KEY=replace-with-a-secure-secret-key-for-session-signing

# Database Connection (Neon PostgreSQL in Production, Postgres Container locally)
# Async driver url for SQLAlchemy asyncio
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/xeno
# Sync driver url for Alembic migrations
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/xeno

# Queue Configuration (Upstash Redis in Production, Local Redis container locally)
REDIS_URL=redis://localhost:6379/0

# Gemini API Integration
GEMINI_API_KEY=your-gemini-api-key-here

# Local Directory Paths for Storage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
