# ── System Configuration ─────────────────────────────────────────────────────
ENV=production
DEBUG=false
SECRET_KEY=replace-with-a-secure-secret-key-for-session-signing

# ── Database ──────────────────────────────────────────────────────────────────
# Passed as individual components to avoid URL-encoding issues with special chars
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=your-render-postgres-host.render.com
DB_PORT=5432
DB_NAME=xeno

# ── Database Pool Configuration ───────────────────────────────────────────────
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── Queue ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://your-render-redis-host.render.com:6379/0

# ── AI — Groq API (https://console.groq.com) ─────────────────────────────────
# Model: llama-3.3-70b-versatile
GROQ_API_KEY=your-groq-api-key-here

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# ── Upload Limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=52428800
